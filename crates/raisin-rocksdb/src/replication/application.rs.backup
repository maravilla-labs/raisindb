    /// Apply a NodeType delete operation
    async fn apply_delete_nodetype(
        &self,
        tenant_id: &str,
        repo_id: &str,
        branch: &str,
        node_type_id: &str,
        op: &Operation,
    ) -> Result<()> {
        tracing::info!(
            "📥 Applying NodeType delete: {}/{}/{}/{} from node {}",
            tenant_id,
            repo_id,
            branch,
            node_type_id,
            op.cluster_node_id
        );

        // For schema deletes, we need to delete all revisions
        // Use a prefix scan to find and delete all versions
        let prefix = keys::nodetype_name_prefix(tenant_id, repo_id, branch, node_type_id);
        let cf = cf_handle(&self.db, cf::NODE_TYPES)?;

        let keys_to_delete: Vec<Vec<u8>> = self
            .db
            .iterator_cf(
                cf,
                rocksdb::IteratorMode::From(&prefix, rocksdb::Direction::Forward),
            )
            .take_while(|result| {
                if let Ok((key, _)) = result {
                    key.starts_with(&prefix)
                } else {
                    false
                }
            })
            .filter_map(|result| result.ok().map(|(key, _)| key.to_vec()))
            .collect();

        for key in keys_to_delete {
            self.db
                .delete_cf(cf, key)
                .map_err(|e| raisin_error::Error::storage(e.to_string()))?;
        }

        tracing::info!(
            "✅ NodeType deleted successfully: {}/{}/{}/{}",
            tenant_id,
            repo_id,
            branch,
            node_type_id
        );

        // Emit SchemaEvent for indexing and job processing
        self.emit_schema_event(
            tenant_id,
            repo_id,
            branch,
            node_type_id,
            "NodeType",
            raisin_events::SchemaEventKind::NodeTypeDeleted,
        );

        Ok(())
    }

