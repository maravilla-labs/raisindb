{
  "name": "@raisindb/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive CLI for RaisinDB with Ink-based terminal UI",
  "bin": {
    "raisindb": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "cd ../../tooling/packages/raisin-schema-wasm && ./build.sh",
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx watch src/index.tsx",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@raisindb/client": "workspace:*",
    "@raisindb/schema-wasm": "workspace:*",
    "archiver": "^7.0.1",
    "cfonts": "^3.3.1",
    "chokidar": "^3.5.3",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "eventsource": "^3.0.5",
    "extract-zip": "^2.0.1",
    "ignore": "^7.0.5",
    "ink": "^5.0.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^10.0.0",
    "react": "^18.2.0",
    "sql-highlight": "^6.0.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/eventsource": "^1.1.15",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18"
      }
    }
  },
  "keywords": [
    "raisindb",
    "cli",
    "terminal",
    "ink",
    "interactive"
  ],
  "author": "Maravilla Labs",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maravilla-labs/raisindb.git",
    "directory": "packages/raisindb-cli"
  }
}
