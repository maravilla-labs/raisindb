{
  "name": "@raisindb/client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client SDK for RaisinDB WebSocket protocol",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "raisindb",
    "database",
    "websocket",
    "cms",
    "content-management",
    "typescript",
    "client"
  ],
  "author": "SOLUTAS GmbH",
  "license": "BSL-1.1",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "events": "^3.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ws": "^8.14.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maravilla-labs/raisindb.git",
    "directory": "packages/raisin-client-js"
  },
  "bugs": {
    "url": "https://github.com/maravilla-labs/raisindb/issues"
  },
  "homepage": "https://raisindb.com",
  "overrides": {
    "glob": ">=10.5.0",
    "js-yaml": ">=4.1.1",
    "esbuild": ">=0.25.0"
  }
}
